# Variables de entorno para Acero y Roca
# Copia este archivo como .env.local para desarrollo local
# En Vercel, configura estas variables en: Settings > Environment Variables

# ---------------------------------------------------------
# OBLIGATORIA: API Key de Google Gemini (IA del asistente)
# Obtener en: https://aistudio.google.com/app/apikey
# ---------------------------------------------------------
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# ---------------------------------------------------------
# OBLIGATORIA: Supabase (base de datos y autenticación)
# Obtener en: https://supabase.com/dashboard/project/_/settings/api
# ---------------------------------------------------------
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_de_supabase_aqui

# ---------------------------------------------------------
# OPCIONAL: Metals API (cotizaciones en tiempo real)
# Sin esta key, la app usa precios de referencia simulados.
# Obtener en: https://metals-api.com
# ---------------------------------------------------------
METALS_API_KEY=tu_metals_api_key_aqui
