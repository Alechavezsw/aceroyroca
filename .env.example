# ══════════════════════════════════════════════════════
#  ACERO & ROCA — Variables de entorno
#  Local: copiar a .env.local
#  Vercel: Settings → Environment Variables (Production + Preview)
# ══════════════════════════════════════════════════════

# ── OBLIGATORIA (servidor) ─────────────────────────────
# Agente IA, briefing, copiloto del editor
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── OPCIONAL (frontend — se embeben en el build) ─────
# Sin esto la app funciona en modo local (localStorage)
# Supabase → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── OPCIONAL (servidor) ──────────────────────────────
# Ticker de commodities en vivo; sin esto usa precios de referencia
# https://metals-api.com
METALS_API_KEY=

# ── OPCIONAL (API externa /api/agent/*) ──────────────
AGENT_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
